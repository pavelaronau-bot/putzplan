# Копия для локального запуска: cp .env.example .env
# Реальные секреты в репозиторий не попадают; в production — из secret manager.

APP_ENV=development
PORT=8000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=putzplan_dev
DB_RUNTIME_USER=putzplan_runtime
DB_RUNTIME_PASSWORD=change_me_runtime
DB_AUDIT_USER=putzplan_audit
DB_AUDIT_PASSWORD=change_me_audit
DB_MIGRATION_USER=putzplan_migration
DB_MIGRATION_PASSWORD=change_me_migration
DB_READONLY_PASSWORD=change_me_readonly
DB_POOL_SIZE=10

# Обязателен в production: без собственного значения приложение не стартует
JWT_SECRET=dev-only-change-me
ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=30

MAX_FAILED_ATTEMPTS=5
LOCK_MINUTES=15
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=900

CORS_ORIGINS=http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1,api,testserver
USE_REFRESH_COOKIE=true

VITE_API_URL=http://localhost:8000
